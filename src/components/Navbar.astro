---
// Get current locale and path
const currentLocale = Astro.currentLocale ?? 'en';
const isZh = currentLocale === 'zh';
const currentPath = Astro.url.pathname;

// Build path for other language
function getAltPath(path: string, fromZh: boolean): string {
  // Check if it's a blog post path: /blog/category/slug/ or /zh/blog/category/slug/
  const isBlogPost = /^\/(zh\/)?blog\/[^/]+\/[^/]+\/?$/.test(path);

  // For blog post pages, link to blog listing page in other language
  if (isBlogPost) {
    return fromZh ? '/blog' : '/zh/blog';
  }

  if (fromZh) {
    // From zh to en: remove /zh prefix
    return path.replace(/^\/zh(\/|$)/, '$1') || '/';
  } else {
    // From en to zh: add /zh prefix
    if (path === '/') {
      return '/zh';
    }
    return '/zh' + path;
  }
}

// Current page and alt language page paths
const homePath = isZh ? '/zh' : '/';
const blogPath = isZh ? '/zh/blog' : '/blog';
const altPath = getAltPath(currentPath, isZh);
const altLabel = isZh ? 'English' : '中文';
---

<script define:vars={{ menuId: 'mobile-menu', buttonId: 'menu-button' }}>
  let isOpen = false;

  function toggleMenu() {
    const menu = document.getElementById(menuId);
    const button = document.getElementById(buttonId);
    const iconOpen = button?.querySelector('.icon-open');
    const iconClose = button?.querySelector('.icon-close');

    isOpen = !isOpen;

    // Toggle menu visibility
    if (menu) {
      menu.classList.toggle('hidden');
    }

    // Toggle icons
    if (iconOpen && iconClose) {
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
    }

    // Update aria-expanded
    if (button) {
      button.setAttribute('aria-expanded', isOpen.toString());
    }
  }

  // Expose function globally
  window.toggleMenu = toggleMenu;
</script>

<style>
  /* Passion-inspired navbar with creative color scheme */
  .navbar-passion {
    background-color: var(--navbar-bg);
    transition: background-color 0.3s ease;
  }

  .navbar-logo {
    color: var(--navbar-logo);
    transition: color 0.3s ease;
  }

  .navbar-link {
    color: var(--navbar-link);
    transition: color 0.3s ease;
  }

  .navbar-link:hover {
    filter: brightness(1.15);
  }
</style>

<nav class="border-b border-bg-tertiary navbar-passion sticky top-0 z-50">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 justify-between">
      <!-- Logo -->
      <div class="flex">
        <a href={homePath} class="flex flex-shrink-0 items-center">
          <span class="text-xl font-bold font-serif navbar-logo">Hepmad</span>
        </a>
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center space-x-8">
        <a href={homePath} class="navbar-link transition-colors">
          {isZh ? '首页' : 'Home'}
        </a>
        <a href={blogPath} class="navbar-link transition-colors">
          {isZh ? '博客' : 'Blog'}
        </a>
        <a href={altPath} class="navbar-link transition-colors" title={altLabel}>
          {altLabel}
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <div class="flex items-center md:hidden">
        <button
          id="menu-button"
          type="button"
          onclick="toggleMenu()"
          class="inline-flex items-center justify-center rounded-md p-2 navbar-link hover:opacity-80 transition-opacity"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>

          <!-- Hamburger Icon (shown when closed) -->
          <svg class="icon-open block h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>

          <!-- Close Icon X (hidden by default) -->
          <svg class="icon-close hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu (hidden by default) -->
  <div class="hidden md:hidden" id="mobile-menu">
    <div class="navbar-passion px-2 pt-2 pb-3 space-y-1">
      <a
        href={homePath}
        onclick="toggleMenu()"
        class="block rounded-md px-3 py-2 text-base font-medium navbar-link transition-colors"
      >
        {isZh ? '首页' : 'Home'}
      </a>
      <a
        href={blogPath}
        onclick="toggleMenu()"
        class="block rounded-md px-3 py-2 text-base font-medium navbar-link transition-colors"
      >
        {isZh ? '博客' : 'Blog'}
      </a>
      <a
        href={altPath}
        onclick="toggleMenu()"
        class="block rounded-md px-3 py-2 text-base font-medium navbar-link transition-colors"
        title={altLabel}
      >
        {altLabel}
      </a>
    </div>
  </div>
</nav>
