---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Generate static paths for each category
export function getStaticPaths() {
  return [
    { params: { category: 'life-story' } },
    { params: { category: 'global-travel' } },
    { params: { category: 'solo-dev' } },
  ];
}

// Get the category from the URL
const { category } = Astro.params;

// Validate category
const validCategories = ['life-story', 'global-travel', 'solo-dev'];
if (!validCategories.includes(category)) {
  return Astro.redirect('/404');
}

// Get all blog posts
const allPosts = await getCollection('blog');

// Sort by date (newest first)
const sortedPosts = allPosts.sort((a, b) =>
  b.data.date.valueOf() - a.data.date.valueOf()
);

// Filter posts by category
const displayPosts = sortedPosts.filter(post => post.data.category === category);

// Category display names
const categoryNames: Record<string, string> = {
  'life-story': 'Life Story',
  'global-travel': 'Global Travel',
  'solo-dev': 'Solo Dev',
};
---

<BaseLayout title={`Hepmad - ${categoryNames[category]}`}>
  <div class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <h1 class="text-4xl font-bold font-serif tracking-tight text-text-primary">{categoryNames[category]}</h1>

      <!-- Category Filter -->
      <div class="mt-10 flex flex-wrap gap-3">
        <a
          href="/blog"
          class="rounded-md bg-tag-bg-inactive px-5 py-2 text-tag-text-inactive border-2 border-tag-border hover:text-text-primary font-medium transition-all"
        >
          All
        </a>
        <a
          href="/blog/life-story"
          class={category === 'life-story' ? 'rounded-md bg-tag-bg-active px-5 py-2 text-tag-text-active border-2 border-tag-border font-medium transition-all' : 'rounded-md bg-tag-bg-inactive px-5 py-2 text-tag-text-inactive border-2 border-tag-border hover:text-text-primary font-medium transition-all'}
        >
          Life Story
        </a>
        <a
          href="/blog/global-travel"
          class={category === 'global-travel' ? 'rounded-md bg-tag-bg-active px-5 py-2 text-tag-text-active border-2 border-tag-border font-medium transition-all' : 'rounded-md bg-tag-bg-inactive px-5 py-2 text-tag-text-inactive border-2 border-tag-border hover:text-text-primary font-medium transition-all'}
        >
          Global Travel
        </a>
        <a
          href="/blog/solo-dev"
          class={category === 'solo-dev' ? 'rounded-md bg-tag-bg-active px-5 py-2 text-tag-text-active border-2 border-tag-border font-medium transition-all' : 'rounded-md bg-tag-bg-inactive px-5 py-2 text-tag-text-inactive border-2 border-tag-border hover:text-text-primary font-medium transition-all'}
        >
          Solo Dev
        </a>
      </div>

      <!-- Blog Posts -->
      <div class="mt-12 space-y-10">
        {displayPosts.length === 0 ? (
          <p class="text-center text-text-muted">No posts found in this category yet.</p>
        ) : (
          displayPosts.map((post) => (
            <article class="border-b border-bg-tertiary pb-10 last:border-0">
              <h2 class="text-2xl font-bold font-serif text-text-primary">
                <a href={`/blog/${post.slug}`} class="hover:text-accent-blue transition-colors">
                  {post.data.title}
                </a>
              </h2>
              <p class="mt-2 text-sm text-text-muted">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · {categoryNames[post.data.category] || post.data.category.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase())}
              </p>
              <p class="mt-3 text-text-secondary">
                {post.data.description}
              </p>
              <a href={`/blog/${post.slug}`} class="mt-4 inline-block text-accent-blue hover:text-accent-blue/80 transition-colors">
                Read more →
              </a>
            </article>
          ))
        )}
      </div>
    </div>
  </div>
</BaseLayout>
